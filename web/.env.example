FRED_API_KEY=
BEA_API_KEY=
CENSUS_API_KEY=
GROQ_API_KEY=
# Second Groq org key — used only on HTTP 429 rate limits (separate free-tier quota)
GROQ_API_KEY_FALLBACK=
# Groq free tier — default openai/gpt-oss-120b (replaces deprecated llama-3.3-70b-versatile)
GROQ_MODEL=openai/gpt-oss-120b
# Smaller model after rate limits; llama-3.1-8b-instant sunsets 2026-08-16
GROQ_FALLBACK_MODEL=openai/gpt-oss-20b
# Cap narrative JSON output tokens per request (default 1800)
GROQ_MAX_COMPLETION_TOKENS=1800
# Optional: Filed.dev SOS entity lookup (~100 free/month) — org_state / file number autofill
FILED_API_KEY=
# Optional PAID fallback — leave unset for fully free operation (Groq + rule-based prose only)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Optional: require API key for POST /api/parse-tax-return (external integrations)
# PARSE_TAX_API_KEY=your_secret_key

# Set to 1 on Vercel production (enables vercel-fast / vercel-balanced / vercel-thorough UI modes)
# NEXT_PUBLIC_VERCEL=1

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Two-phase Tesseract OCR (scripts/free-ocr.cjs)
# Mode preset: fast | balanced | thorough | vercel-fast | vercel-balanced
FREE_OCR_MODE=balanced
FREE_OCR_QUICK_SCALE=0.5
FREE_OCR_PDF_SCALE=1.65
FREE_OCR_MIN_ROW_CONFIDENCE=50
FREE_OCR_TIMEOUT_MS=1200000
# Limit high-res OCR pages (0 = no cap). Use e.g. 4 while testing.
FREE_OCR_MAX_PAGES=0
# After keyword/heuristic page pick, cap how many get full-res OCR (0 = no cap).
FREE_OCR_MAX_PHASE2_PAGES=26
# Set to 1 to skip keyword scan and use heuristics only (debug).
FREE_OCR_SKIP_PHASE1=0
# Parallel Tesseract workers (local dev: 2-3; Vercel Hobby: always use 1 — auto when VERCEL=1)
FREE_OCR_WORKERS=1
